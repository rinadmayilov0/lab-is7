<!DOCTYPE html>
<html>
<head>
    <title>Tapşiriq 2</title>
</head>
<body>

    <input type="text" id="n1">
    <input type="text" id="n2">
    <button onclick="topla()">+</button>
    <button onclick="cix()">-</button>
    <p id="res">0</p>

    <script src="script.js"></script>
</body>
</html>

SCRIPT

function topla() {
    var a = Number(document.getElementById("n1").value);
    var b = Number(document.getElementById("n2").value);
    document.getElementById("res").innerHTML = a + b;
}

function cix() {
    var a = Number(document.getElementById("n1").value);
    var b = Number(document.getElementById("n2").value);
    document.getElementById("res").innerHTML = a - b;
}
